# Copy this file to .env and fill in your key.
# .env is gitignored and will not be committed.

# Required: get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-key-here

# Optional overrides — defaults shown
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# Want to use a different OpenAI-compatible endpoint instead?
# Comment out the DeepSeek vars above and uncomment one of these blocks.

# --- Official OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- Local Ollama ---
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
